// ═══════════════════════════════════════════════
//  VALIDATION HELPERS
// ═══════════════════════════════════════════════
function setError(fieldId, show){
  document.getElementById(fieldId).classList.toggle('has-error', show);
}

function isEmail(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

// ═══════════════════════════════════════════════
//  STEP SUBMISSIONS
// ═══════════════════════════════════════════════
function submitStep0Register(){
  const name = document.getElementById('inp-fullname').value.trim();
  const email= document.getElementById('inp-email').value.trim();
  const pw   = document.getElementById('inp-password').value;

  let ok = true;
  if(!name){  setError('f-fullname',true); ok=false; } else setError('f-fullname',false);
  if(!isEmail(email)){ setError('f-email',true); document.getElementById('email-err').textContent='Enter a valid email'; ok=false; }
  else {
    // Check duplicate
    const users = JSON.parse(localStorage.getItem('sr_users')||'[]');
    if(users.find(u=>u.email.toLowerCase()===email.toLowerCase())){
      setError('f-email',true); document.getElementById('email-err').textContent='This email is already registered'; ok=false;
    } else setError('f-email',false);
  }
  if(pw.length<6){ setError('f-password',true); ok=false; } else setError('f-password',false);
  if(!ok) return;

  profile.fullName     = name;
  profile.email        = email;
  profile.passwordHash = simpleHash(pw);
  showStep(1);
}

function submitLogin(){
  const email = document.getElementById('inp-li-email').value.trim();
  const pw    = document.getElementById('inp-li-password').value;
  let ok = true;
  if(!isEmail(email)){ setError('f-li-email',true); ok=false; } else setError('f-li-email',false);
  if(!pw){ setError('f-li-password',true); ok=false; } else setError('f-li-password',false);
  if(!ok) return;

  const users = JSON.parse(localStorage.getItem('sr_users')||'[]');
  const user  = users.find(u=>u.email.toLowerCase()===email.toLowerCase());

  if(!user || user.passwordHash !== simpleHash(pw)){
    setError('f-li-email',true);
    setError('f-li-password',true);
    document.querySelector('#f-li-password .field-error').textContent = 'Email or password is incorrect';
    return;
  }

  // Log in
  user.loggedIn = true;
  localStorage.setItem('sr_profile', JSON.stringify(user));
  // Restore user's data keys
  if(user.dataKey){
    const data = JSON.parse(localStorage.getItem(user.dataKey)||'{}');
    if(data.sales)     localStorage.setItem('smartretail_sales',     JSON.stringify(data.sales));
    if(data.inventory) localStorage.setItem('smartretail_inventory', JSON.stringify(data.inventory));
    localStorage.setItem('smartretail_settings', JSON.stringify({ storeName:user.shopName, currency:user.currency }));
  }
  window.location.href='index.html';
}

function submitStep1(){
  const shopName = document.getElementById('inp-shopname').value.trim();
  const bizChip  = document.querySelector('#chips-biztype .chip.selected');

  let ok = true;
  if(!shopName){ setError('f-shopname',true); ok=false; } else setError('f-shopname',false);
  if(!bizChip){
    document.getElementById('biztype-err').style.display='block';
    ok=false;
  } else {
    document.getElementById('biztype-err').style.display='none';
  }
  if(!ok) return;

  profile.shopName = shopName;
  profile.bizType  = bizChip.textContent.trim();
  profile.currency = document.getElementById('inp-currency').value;
  showStep(2);
}

function submitStep2(){
  const selected = Array.from(document.querySelectorAll('#chips-categories .chip.selected'))
                        .map(c=>c.textContent.trim());
  const other    = document.getElementById('inp-other-cat').value.trim();
  if(other) selected.push(other);

  if(selected.length===0){
    document.getElementById('cat-err').style.display='block';
    return;
  }
  document.getElementById('cat-err').style.display='none';

  profile.categories = selected;
  profile.otherCat   = other;
  showStep(3);
}

function submitStep3(){
  // Avatar
  const avatarEl = document.querySelector('#avatar-grid .avatar-opt.selected');
  profile.avatar = avatarEl ? avatarEl.textContent.trim() : '🏪';

  // Toggles
  profile.expiryTracking   = document.getElementById('tog-expiry').classList.contains('on');
  profile.autoDeduct       = document.getElementById('tog-autodeduct').classList.contains('on');
  profile.customerTracking = document.getElementById('tog-customer').classList.contains('on');

  // Save user to users list
  const users    = JSON.parse(localStorage.getItem('sr_users')||'[]');
  const dataKey  = 'sr_data_' + simpleHash(profile.email);
  profile.dataKey  = dataKey;
  profile.loggedIn = true;
  profile.createdAt= new Date().toISOString();

  users.push({...profile});
  localStorage.setItem('sr_users', JSON.stringify(users));
  localStorage.setItem('sr_profile', JSON.stringify(profile));

  // Set app settings
  localStorage.setItem('smartretail_settings', JSON.stringify({
    storeName: profile.shopName,
    currency:  profile.currency
  }));

  buildWelcome();
  showStep(4);
}

// ═══════════════════════════════════════════════
//  WELCOME SCREEN
// ═══════════════════════════════════════════════
function buildWelcome(){
  const firstName = profile.fullName.split(' ')[0];
  document.getElementById('welcome-name').textContent = `You're all set, ${firstName}! ${profile.avatar}`;

  const topCats = profile.categories.slice(0,3).map(c=>{
    const emoji = c.split(' ')[0];
    return `<span>${emoji}</span> ${c.split(' ').slice(1).join(' ')}`;
  }).join(' · ');

  document.getElementById('welcome-sub').innerHTML =
    `Your store is customized and ready.<br/>Here's a summary of your setup:`;

  const tags = [
    { label:'Store',    value: profile.shopName },
    { label:'Type',     value: profile.bizType },
    { label:'Currency', value: profile.currency },
    { label:'Selling',  value: profile.categories.slice(0,2).map(c=>c.split(' ').slice(1).join(' ')).join(', ') + (profile.categories.length>2?` +${profile.categories.length-2} more`:'') },
    { label:'Expiry Alerts', value: profile.expiryTracking?'On':'Off' },
    { label:'Auto Deduct',   value: profile.autoDeduct?'On':'Off' },
  ];

  document.getElementById('welcome-tags').innerHTML = tags.map(t=>
    `<div class="welcome-tag">${t.label}: <span>${t.value}</span></div>`
  ).join('');
}

function launchApp(){
  window.location.href='index.html';
}
