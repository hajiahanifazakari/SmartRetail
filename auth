<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SmartRetail — Get Started</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0F1B2D;
  --navy-2:#162438;
  --navy-3:#1E3050;
  --amber:#F59E0B;
  --emerald:#10B981;
  --coral:#EF4444;
  --white:#F8FAFC;
  --muted:#94A3B8;
  --border:#1E3050;
  --radius:14px;
  --shadow:0 8px 40px rgba(0,0,0,0.4);
}
html,body{min-height:100vh;font-family:'Inter',sans-serif;background:var(--navy);color:var(--white);}

/* ── BACKGROUND PATTERN ── */
body{
  background-color:var(--navy);
  background-image:
    radial-gradient(circle at 20% 20%, rgba(245,158,11,0.06) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(16,185,129,0.05) 0%, transparent 50%);
}

/* ── LAYOUT ── */
.auth-wrap{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px 16px;
}

.auth-card{
  background:var(--navy-2);
  border:1px solid var(--border);
  border-radius:24px;
  padding:40px 36px;
  width:100%;
  max-width:480px;
  box-shadow:var(--shadow);
  position:relative;
  overflow:hidden;
}

/* Subtle glow top bar */
.auth-card::before{
  content:'';
  position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg, var(--amber), var(--emerald));
}

/* ── BRAND ── */
.auth-brand{text-align:center;margin-bottom:32px;}
.auth-brand-icon{
  width:60px;height:60px;
  background:var(--amber);
  border-radius:16px;
  display:inline-flex;align-items:center;justify-content:center;
  font-size:28px;margin-bottom:14px;
  box-shadow:0 4px 20px rgba(245,158,11,0.35);
}
.auth-brand-name{
  font-family:'Sora',sans-serif;
  font-size:1.6rem;font-weight:800;
  letter-spacing:-0.5px;
}
.auth-brand-name span{color:var(--amber);}
.auth-brand-sub{color:var(--muted);font-size:0.82rem;margin-top:4px;}

/* ── PROGRESS DOTS ── */
.progress-wrap{
  display:flex;align-items:center;justify-content:center;
  gap:6px;margin-bottom:28px;
}
.dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--navy-3);border:1px solid var(--border);
  transition:all 0.3s ease;
}
.dot.active{background:var(--amber);border-color:var(--amber);transform:scale(1.25);}
.dot.done{background:var(--emerald);border-color:var(--emerald);}
.dot-line{width:24px;height:2px;background:var(--navy-3);border-radius:2px;transition:background 0.3s;}
.dot-line.done{background:var(--emerald);}

/* ── STEPS ── */
.step{display:none;}
.step.active{display:block;}

.step-eyebrow{
  font-size:0.68rem;font-weight:600;letter-spacing:1.2px;
  text-transform:uppercase;color:var(--amber);margin-bottom:6px;
}
.step-title{
  font-family:'Sora',sans-serif;
  font-size:1.25rem;font-weight:800;margin-bottom:6px;
  line-height:1.3;
}
.step-desc{color:var(--muted);font-size:0.82rem;margin-bottom:24px;line-height:1.5;}

/* ── FORM ELEMENTS ── */
.field{margin-bottom:16px;}
.field label{
  display:block;
  font-size:0.73rem;font-weight:600;letter-spacing:0.5px;
  text-transform:uppercase;color:var(--muted);margin-bottom:7px;
}
.field input,.field select{
  width:100%;
  background:var(--navy-3);
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:12px 14px;
  color:var(--white);
  font-family:'Inter',sans-serif;font-size:0.9rem;
  outline:none;
  transition:border-color 0.2s,box-shadow 0.2s;
}
.field input:focus,.field select:focus{
  border-color:var(--amber);
  box-shadow:0 0 0 3px rgba(245,158,11,0.12);
}
.field input::placeholder{color:var(--muted);}
.field select option{background:var(--navy-2);}

/* ── CHIP SELECTOR ── */
.chip-group{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:4px;}
.chip{
  padding:8px 16px;border-radius:99px;
  border:1.5px solid var(--border);
  background:var(--navy-3);
  color:var(--muted);
  font-size:0.8rem;font-weight:500;
  cursor:pointer;transition:all 0.15s ease;
  user-select:none;
}
.chip:hover{border-color:var(--amber);color:var(--white);}
.chip.selected{
  background:var(--amber);color:var(--navy);
  border-color:var(--amber);font-weight:700;
}

/* ── TOGGLE SWITCH ── */
.toggle-row{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--navy-3);border:1.5px solid var(--border);
  border-radius:10px;padding:12px 14px;margin-bottom:12px;cursor:pointer;
  transition:border-color 0.2s;
}
.toggle-row:hover{border-color:var(--amber);}
.toggle-row.on{border-color:var(--emerald);}
.toggle-label{font-size:0.88rem;font-weight:500;}
.toggle-sub{font-size:0.72rem;color:var(--muted);margin-top:1px;}
.toggle-pill{
  width:42px;height:24px;border-radius:99px;
  background:var(--border);position:relative;
  transition:background 0.2s;flex-shrink:0;
}
.toggle-row.on .toggle-pill{background:var(--emerald);}
.toggle-pill::after{
  content:'';position:absolute;
  top:3px;left:3px;
  width:18px;height:18px;border-radius:50%;
  background:#fff;transition:transform 0.2s;
}
.toggle-row.on .toggle-pill::after{transform:translateX(18px);}

/* ── PASSWORD FIELD ── */
.pw-wrap{position:relative;}
.pw-wrap input{padding-right:42px;}
.pw-eye{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;
  font-size:1rem;color:var(--muted);padding:4px;
}
.pw-eye:hover{color:var(--white);}

/* ── STRENGTH BAR ── */
.strength-wrap{margin-top:6px;}
.strength-bar-bg{height:4px;background:var(--navy-3);border-radius:99px;overflow:hidden;margin-bottom:4px;}
.strength-bar-fill{height:100%;border-radius:99px;transition:width 0.3s,background 0.3s;width:0%;}
.strength-text{font-size:0.7rem;color:var(--muted);}

/* ── BUTTON ── */
.btn-full{
  width:100%;padding:13px;border-radius:11px;
  font-family:'Sora',sans-serif;font-size:0.95rem;font-weight:700;
  cursor:pointer;border:none;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:all 0.2s;margin-top:20px;
}
.btn-primary{background:var(--amber);color:var(--navy);}
.btn-primary:hover{background:#FBBF24;transform:translateY(-1px);box-shadow:0 4px 20px rgba(245,158,11,0.4);}
.btn-primary:disabled{opacity:0.5;cursor:not-allowed;transform:none;box-shadow:none;}
.btn-ghost{background:transparent;color:var(--muted);font-size:0.82rem;margin-top:10px;border:none;cursor:pointer;font-family:'Inter',sans-serif;}
.btn-ghost:hover{color:var(--white);}

/* ── BACK LINK ── */
.back-btn{
  background:none;border:none;cursor:pointer;
  color:var(--muted);font-size:0.82rem;font-family:'Inter',sans-serif;
  display:flex;align-items:center;gap:6px;margin-bottom:20px;
  transition:color 0.2s;
}
.back-btn:hover{color:var(--white);}

/* ── WELCOME / SUCCESS ── */
.welcome-wrap{text-align:center;padding:16px 0;}
.welcome-icon{font-size:4rem;margin-bottom:16px;display:block;animation:popIn 0.5s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes popIn{from{transform:scale(0);opacity:0;}to{transform:scale(1);opacity:1;}}
.welcome-title{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;margin-bottom:8px;}
.welcome-sub{color:var(--muted);font-size:0.88rem;line-height:1.6;}
.welcome-tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:16px 0;}
.welcome-tag{
  background:var(--navy-3);border:1px solid var(--border);
  border-radius:8px;padding:6px 12px;font-size:0.78rem;
}
.welcome-tag span{color:var(--amber);font-weight:600;}

/* ── LOGIN SCREEN ── */
.login-toggle{
  display:flex;border:1.5px solid var(--border);
  border-radius:10px;overflow:hidden;margin-bottom:24px;
}
.login-tab{
  flex:1;padding:10px;text-align:center;
  background:none;border:none;cursor:pointer;
  font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:600;
  color:var(--muted);transition:all 0.2s;
}
.login-tab.active{background:var(--amber);color:var(--navy);}

/* ── DIVIDER ── */
.divider{
  display:flex;align-items:center;gap:12px;
  margin:16px 0;color:var(--muted);font-size:0.75rem;
}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── ERROR ── */
.field-error{
  font-size:0.72rem;color:var(--coral);margin-top:5px;display:none;
}
.field.has-error input,.field.has-error select{border-color:var(--coral);}
.field.has-error .field-error{display:block;}

/* ── AVATAR PICKER ── */
.avatar-grid{display:flex;gap:10px;flex-wrap:wrap;}
.avatar-opt{
  width:46px;height:46px;border-radius:12px;
  background:var(--navy-3);border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;cursor:pointer;transition:all 0.15s;
}
.avatar-opt:hover{border-color:var(--amber);}
.avatar-opt.selected{border-color:var(--amber);background:rgba(245,158,11,0.15);}

/* ── RESPONSIVE ── */
@media(max-width:520px){
  .auth-card{padding:28px 20px;border-radius:18px;}
  .auth-brand-name{font-size:1.35rem;}
  .step-title{font-size:1.1rem;}
}
</style>
</head>
<body>

<div class="auth-wrap">
  <div class="auth-card">

    <!-- BRAND -->
    <div class="auth-brand">
      <div class="auth-brand-icon">🛒</div>
      <div class="auth-brand-name">Smart<span>Retail</span></div>
      <div class="auth-brand-sub" id="auth-subtitle">Pocket Business Manager</div>
    </div>

    <!-- PROGRESS DOTS -->
    <div class="progress-wrap" id="progress-wrap">
      <div class="dot active" id="dot-0"></div>
      <div class="dot-line" id="line-0"></div>
      <div class="dot" id="dot-1"></div>
      <div class="dot-line" id="line-1"></div>
      <div class="dot" id="dot-2"></div>
      <div class="dot-line" id="line-2"></div>
      <div class="dot" id="dot-3"></div>
    </div>

    <!-- ═══ STEP 0: LOGIN / REGISTER TOGGLE ═══ -->
    <div class="step active" id="step-0">
      <div class="login-toggle">
        <button class="login-tab active" id="tab-register" onclick="switchTab('register')">New Store</button>
        <button class="login-tab" id="tab-login" onclick="switchTab('login')">Sign In</button>
      </div>

      <!-- REGISTER FORM -->
      <div id="register-form">
        <div class="step-eyebrow">Step 1 of 4</div>
        <div class="step-title">Create your account</div>
        <div class="step-desc">Your details stay private and stored securely on this device.</div>

        <div class="field" id="f-fullname">
          <label for="inp-fullname">Your Full Name *</label>
          <input type="text" id="inp-fullname" placeholder="e.g. Abena Owusu" autocomplete="name"/>
          <div class="field-error">Please enter your name</div>
        </div>
        <div class="field" id="f-email">
          <label for="inp-email">Email Address *</label>
          <input type="email" id="inp-email" placeholder="e.g. abena@gmail.com" autocomplete="email"/>
          <div class="field-error" id="email-err">Enter a valid email</div>
        </div>
        <div class="field" id="f-password">
          <label for="inp-password">Create Password *</label>
          <div class="pw-wrap">
            <input type="password" id="inp-password" placeholder="Min. 6 characters" autocomplete="new-password" oninput="checkStrength()"/>
            <button class="pw-eye" type="button" onclick="togglePw('inp-password',this)">👁</button>
          </div>
          <div class="strength-wrap">
            <div class="strength-bar-bg"><div class="strength-bar-fill" id="strength-fill"></div></div>
            <div class="strength-text" id="strength-text"></div>
          </div>
          <div class="field-error">Password must be at least 6 characters</div>
        </div>

        <button class="btn-full btn-primary" onclick="submitStep0Register()">
          Continue →
        </button>
      </div>

      <!-- LOGIN FORM -->
      <div id="login-form" style="display:none;">
        <div class="step-title">Welcome back 👋</div>
        <div class="step-desc">Sign in to your SmartRetail account.</div>

        <div class="field" id="f-li-email">
          <label for="inp-li-email">Email Address</label>
          <input type="email" id="inp-li-email" placeholder="your@email.com" autocomplete="email"/>
          <div class="field-error">Enter a valid email</div>
        </div>
        <div class="field" id="f-li-password">
          <label for="inp-li-password">Password</label>
          <div class="pw-wrap">
            <input type="password" id="inp-li-password" placeholder="Your password" autocomplete="current-password"/>
            <button class="pw-eye" type="button" onclick="togglePw('inp-li-password',this)">👁</button>
          </div>
          <div class="field-error">Incorrect password</div>
        </div>

        <button class="btn-full btn-primary" onclick="submitLogin()">
          Sign In →
        </button>
        <div style="text-align:center;margin-top:12px;">
          <button class="btn-ghost" onclick="switchTab('register')">Don't have an account? Create one</button>
        </div>
      </div>
    </div>

    <!-- ═══ STEP 1: STORE BASICS ═══ -->
    <div class="step" id="step-1">
      <button class="back-btn" onclick="goBack(1)">← Back</button>
      <div class="step-eyebrow">Step 2 of 4</div>
      <div class="step-title">Tell us about your store</div>
      <div class="step-desc">This helps SmartRetail customize everything for you.</div>

      <div class="field" id="f-shopname">
        <label for="inp-shopname">Shop / Business Name *</label>
        <input type="text" id="inp-shopname" placeholder="e.g. Abena's Boutique"/>
        <div class="field-error">Please enter your shop name</div>
      </div>

      <div class="field">
        <label>Business Type *</label>
        <div class="chip-group" id="chips-biztype">
          <div class="chip" onclick="selectChip(this,'biztype')">🏪 Retail Shop</div>
          <div class="chip" onclick="selectChip(this,'biztype')">📦 Wholesale</div>
          <div class="chip" onclick="selectChip(this,'biztype')">🛍️ Both</div>
          <div class="chip" onclick="selectChip(this,'biztype')">🚶 Mobile / Market</div>
        </div>
        <div class="field-error" id="biztype-err" style="display:none;font-size:0.72rem;color:var(--coral);margin-top:6px;">Please select a business type</div>
      </div>

      <div class="field">
        <label for="inp-currency">Currency</label>
        <select id="inp-currency">
          <option value="GH₵">GH₵ — Ghana Cedis</option>
          <option value="₦">₦ — Nigerian Naira</option>
          <option value="KES">KES — Kenyan Shilling</option>
          <option value="R">R — South African Rand</option>
          <option value="$">$ — US Dollar</option>
          <option value="€">€ — Euro</option>
          <option value="£">£ — British Pound</option>
        </select>
      </div>

      <button class="btn-full btn-primary" onclick="submitStep1()">Continue →</button>
    </div>

    <!-- ═══ STEP 2: WHAT YOU SELL ═══ -->
    <div class="step" id="step-2">
      <button class="back-btn" onclick="goBack(2)">← Back</button>
      <div class="step-eyebrow">Step 3 of 4</div>
      <div class="step-title">What do you sell?</div>
      <div class="step-desc">Select your main product categories. This personalises your dashboard labels.</div>

      <div class="field">
        <label>Product Categories <span style="color:var(--muted);font-weight:400">(pick all that apply)</span></label>
        <div class="chip-group" id="chips-categories">
          <div class="chip" onclick="toggleMultiChip(this)">👗 Clothing & Fashion</div>
          <div class="chip" onclick="toggleMultiChip(this)">🍎 Food & Groceries</div>
          <div class="chip" onclick="toggleMultiChip(this)">💄 Beauty & Cosmetics</div>
          <div class="chip" onclick="toggleMultiChip(this)">📱 Electronics</div>
          <div class="chip" onclick="toggleMultiChip(this)">🏠 Household Items</div>
          <div class="chip" onclick="toggleMultiChip(this)">💊 Pharmacy</div>
          <div class="chip" onclick="toggleMultiChip(this)">👟 Shoes & Bags</div>
          <div class="chip" onclick="toggleMultiChip(this)">🛠️ Hardware & Tools</div>
          <div class="chip" onclick="toggleMultiChip(this)">📚 Books & Stationery</div>
          <div class="chip" onclick="toggleMultiChip(this)">🍳 Kitchenware</div>
        </div>
        <div class="field-error" id="cat-err" style="display:none;font-size:0.72rem;color:var(--coral);margin-top:6px;">Please select at least one category</div>
      </div>

      <div class="field">
        <label for="inp-other-cat">Other (optional)</label>
        <input type="text" id="inp-other-cat" placeholder="e.g. Spare parts, Livestock..."/>
      </div>

      <button class="btn-full btn-primary" onclick="submitStep2()">Continue →</button>
    </div>

    <!-- ═══ STEP 3: PREFERENCES ═══ -->
    <div class="step" id="step-3">
      <button class="back-btn" onclick="goBack(3)">← Back</button>
      <div class="step-eyebrow">Step 4 of 4 — Almost done!</div>
      <div class="step-title">A few quick preferences</div>
      <div class="step-desc">Helps us set your defaults. You can change these later.</div>

      <div class="field">
        <label>Pick a Store Avatar</label>
        <div class="avatar-grid" id="avatar-grid">
          <div class="avatar-opt selected" onclick="selectAvatar(this)">🏪</div>
          <div class="avatar-opt" onclick="selectAvatar(this)">🛍️</div>
          <div class="avatar-opt" onclick="selectAvatar(this)">🏬</div>
          <div class="avatar-opt" onclick="selectAvatar(this)">🛒</div>
          <div class="avatar-opt" onclick="selectAvatar(this)">💼</div>
          <div class="avatar-opt" onclick="selectAvatar(this)">🏷️</div>
        </div>
      </div>

      <div class="field">
        <label>Features to enable</label>
        <div class="toggle-row on" id="tog-expiry" onclick="toggleRow(this)">
          <div><div class="toggle-label">⏰ Expiry Date Tracking</div><div class="toggle-sub">Get alerts before products expire</div></div>
          <div class="toggle-pill"></div>
        </div>
        <div class="toggle-row on" id="tog-autodeduct" onclick="toggleRow(this)">
          <div><div class="toggle-label">📦 Auto Stock Deduction</div><div class="toggle-sub">Reduce inventory when a sale is recorded</div></div>
          <div class="toggle-pill"></div>
        </div>
        <div class="toggle-row" id="tog-customer" onclick="toggleRow(this)">
          <div><div class="toggle-label">👤 Customer Name Tracking</div><div class="toggle-sub">Log customer names with each sale</div></div>
          <div class="toggle-pill"></div>
        </div>
      </div>

      <button class="btn-full btn-primary" onclick="submitStep3()">🚀 Launch My Store</button>
    </div>

    <!-- ═══ STEP 4: WELCOME ═══ -->
    <div class="step" id="step-4">
      <div class="welcome-wrap">
        <span class="welcome-icon">🎉</span>
        <div class="welcome-title" id="welcome-name">Ready to go!</div>
        <div class="welcome-sub" id="welcome-sub">Your store has been set up.<br/>Here's what we've configured for you:</div>
        <div class="welcome-tags" id="welcome-tags"></div>
        <button class="btn-full btn-primary" onclick="launchApp()" style="margin-top:8px;">
          Enter SmartRetail →
        </button>
      </div>
    </div>

  </div><!-- end auth-card -->
</div><!-- end auth-wrap -->

<script>
// ═══════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════
let profile = {
  fullName:'', email:'', passwordHash:'',
  shopName:'', bizType:'', currency:'GH₵',
  categories:[], otherCat:'',
  avatar:'🏪',
  expiryTracking:true, autoDeduct:true, customerTracking:false
};
let currentStep = 0;
let activeTab = 'register';

// ═══════════════════════════════════════════════
//  INIT — redirect if already logged in
// ═══════════════════════════════════════════════
(function(){
  const existing = localStorage.getItem('sr_profile');
  if(existing){
    const p = JSON.parse(existing);
    if(p && p.loggedIn) window.location.href='index.html';
  }
})();

// ═══════════════════════════════════════════════
//  TAB SWITCH
// ═══════════════════════════════════════════════
function switchTab(tab){
  activeTab = tab;
  document.getElementById('register-form').style.display = tab==='register'?'block':'none';
  document.getElementById('login-form').style.display    = tab==='login'?'block':'none';
  document.getElementById('tab-register').classList.toggle('active', tab==='register');
  document.getElementById('tab-login').classList.toggle('active',    tab==='login');
  document.getElementById('auth-subtitle').textContent =
    tab==='login'?'Welcome back':'Pocket Business Manager';
  document.getElementById('progress-wrap').style.display = tab==='register'?'flex':'none';
}

// ═══════════════════════════════════════════════
//  PROGRESS DOTS
// ═══════════════════════════════════════════════
function setProgress(step){
  for(let i=0;i<4;i++){
    const dot = document.getElementById('dot-'+i);
    dot.classList.remove('active','done');
    if(i < step)       dot.classList.add('done');
    else if(i === step) dot.classList.add('active');
  }
  for(let i=0;i<3;i++){
    const line = document.getElementById('line-'+i);
    line.classList.toggle('done', i < step);
  }
}

// ═══════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════
function showStep(n){
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById('step-'+n).classList.add('active');
  setProgress(n);
  currentStep = n;
  // Hide progress on welcome step
  document.getElementById('progress-wrap').style.display = n===4?'none':'flex';
}

function goBack(step){
  showStep(step-1);
}

// ═══════════════════════════════════════════════
//  PASSWORD
// ═══════════════════════════════════════════════
function togglePw(id, btn){
  const inp = document.getElementById(id);
  if(inp.type==='password'){ inp.type='text'; btn.textContent='🙈'; }
  else { inp.type='password'; btn.textContent='👁'; }
}

function checkStrength(){
  const val = document.getElementById('inp-password').value;
  const fill= document.getElementById('strength-fill');
  const txt = document.getElementById('strength-text');
  let score = 0;
  if(val.length>=6) score++;
  if(val.length>=10) score++;
  if(/[A-Z]/.test(val)) score++;
  if(/[0-9]/.test(val)) score++;
  if(/[^A-Za-z0-9]/.test(val)) score++;
  const levels=[
    {w:'0%',  c:'var(--coral)',   t:''},
    {w:'25%', c:'var(--coral)',   t:'Weak'},
    {w:'50%', c:'var(--amber)',   t:'Fair'},
    {w:'75%', c:'var(--amber)',   t:'Good'},
    {w:'100%',c:'var(--emerald)', t:'Strong'},
    {w:'100%',c:'var(--emerald)', t:'Very Strong'}
  ];
  const l = levels[Math.min(score, 5)];
  fill.style.width      = l.w;
  fill.style.background = l.c;
  txt.textContent       = l.t;
  txt.style.color       = l.c;
}

// Simple hash (not cryptographic — for local storage demo only)
function simpleHash(str){
  let h=0;
  for(let i=0;i<str.length;i++){ h=(Math.imul(31,h)+str.charCodeAt(i))|0; }
  return h.toString(36);
}

